# Luna AI Environment Variables
# Copy this file to .env and fill in your values

# Hugging Face API Token (for Chat and Text-to-Speech)
HF_TOKEN=your_huggingface_token_here

# Solana Treasury Wallet Address (receives payments)
TREASURY_WALLET=your_solana_wallet_address_here

# Backend API URL (for message sync, notifications)
# Use localhost for development, deployed URL for production
BACKEND_URL=http://localhost:3000

# OpenAI API Key (for Whisper speech-to-text)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here
